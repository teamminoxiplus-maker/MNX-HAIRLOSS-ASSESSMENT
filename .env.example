# ---------------------------------------------------------------------------
# MINOXIPLUS Free Hair Loss Assessment — environment
# Copy to .env.local (local) or set these in Vercel (production).
# ---------------------------------------------------------------------------

# Supabase (Project Settings -> API). Point this at the same project that holds
# your assessment tables. The service_role key is server-only — never expose it.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site origin (used in result-email links). In production this is the
# app's own URL, e.g. https://assess.minoxiplus.com
NEXT_PUBLIC_SITE_URL=https://minoxiplus.com

# Resend — transactional result email. If unset, submit still succeeds and the
# email step is skipped.
RESEND_API_KEY=
RESEND_FROM_EMAIL=MINOXIPLUS <care@minoxiplus.com>

# Anthropic (Claude) — powers the AI interpretation shown on the result page and
# in the email. If unset, the submit still succeeds and the result falls back to
# the static copy. ANTHROPIC_MODEL is optional (a sensible default is used).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Admin access — comma-separated allowlist of emails permitted at /admin.
# Empty = locked out for everyone.
ADMIN_ALLOWLIST=

# Upstash Redis (REST) for submit rate limiting. If unset, an in-memory
# fallback is used (single-instance / dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Kiosk mode PIN (spec §13). Required to unlock /kiosk.
KIOSK_PIN=

# Salt for hashing client IPs before storage (spec §11). Any random string.
IP_HASH_SALT=
